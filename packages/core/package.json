{
  "name": "@ashui/core",
  "version": "0.0.1",
  "type": "module",
  "files": ["dist"],
  "main": "./dist/ashui.cjs",
  "module": "./dist/ashui.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/ashui.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/ashui.cjs"
      }
    }
  },
  "scripts": {
    "build": "vite build && cp dist/index.d.ts dist/index.d.cts",
    "test": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^29.1.1",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
